---
import Aurora from "../components/Aurora.astro";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body
    class="pt-5 px-8 pb-10 text-indigo-200 relative min-h-full bg-[rgb(22,22,43)]"
  >
    <Aurora />
    <div class="noise"></div>
    <slot />
  </body>
</html>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Fira+Code:wght@700&family=Montserrat:wght@400;500;700&display=swap");
  :root {
    min-width: 320px;
    font-family: "Montserrat", system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, "Open Sans",
      "Helvetica Neue", sans-serif;
    scroll-behavior: smooth;
  }

  .font-heading {
    font-family: "Fira Code", monospace;
    letter-spacing: -0.05em;
  }

  .fade-in {
    animation: fade-in 300ms;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  .nav__link {
    font-size: clamp(0.875rem, 0.7985rem + 0.3265vw, 1.125rem);
  }

  .noise {
    z-index: -1;
    position: absolute;
    inset: 0;
    background-image: url(/assets/noise.webp);
    opacity: 0.4;
    mix-blend-mode: overlay;
    pointer-events: none;
  }
</style>
